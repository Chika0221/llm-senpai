# DB（Neon PostgreSQL）
DATABASE_URL=""

# Discord Bot
DISCORD_TOKEN=""
DISCORD_CLIENT_ID=""
DISCORD_CHANNEL_ID=""

# --- 認証・認可（§5.7 / #10）---
# Discord Developer Portal で発行するクライアントシークレット
DISCORD_CLIENT_SECRET=""
# OAuth2 リダイレクトURI（Portal の Redirects と一致させる）
DISCORD_OAUTH_REDIRECT_URI="http://localhost:7070/auth/discord/callback"
# 部員判定に使う対象ギルドID
DISCORD_GUILD_ID=""
# 役割判定に使うロールID
ROLE_ID_KISO=""    # 基礎班 = 後輩
ROLE_ID_HATTEN=""  # 発展班 = 先輩
# JWT セッション署名用シークレット（十分に長いランダム文字列）
SESSION_SECRET=""
# フロントエンドのオリジン（CORS 許可・ログイン後リダイレクト先）
WEB_ORIGIN="http://localhost:3000"
# クロスオリジン運用時に Cookie を共有させたい場合のドメイン（任意）
# COOKIE_DOMAIN=""
