datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum RequestSource {
  WEB
  API
}

enum SessionStatus {
  OPEN // セッション進行中（やり取り中）
  WAITING // 先輩の返答待ち
  EXECUTING // 後輩のシェルでコマンド実行中（結果待ち）
  COMPLETED // 解決済み（終了）
  ERROR
}

enum MessageRole {
  USER // 後輩（ユーザー）
  ASSISTANT // 先輩（AIのフリ）
  TOOL // コマンド実行結果
}

// コマンド実行（Tool Call）の後輩側承認状態（§5.4 安全要件）
enum ApprovalStatus {
  PENDING // 承認待ち
  APPROVED // 後輩が承認・実行許可
  REJECTED // 後輩が拒否
}

// ギルドロールから判定するユーザー役割（§5.7 認証・認可）
enum UserRole {
  KISO // 基礎班 = 後輩（質問側）。未割り当ての部員もこれに準ずる最小権限
  HATTEN // 発展班 = 先輩（回答側・ダッシュボード利用可）
}

// 1つの質問・会話の単位（Discordのスレッドに対応）
model Session {
  id              String        @id @default(uuid())
  source          RequestSource
  discordThreadId String?       @unique // DiscordのスレッドID
  status          SessionStatus @default(OPEN)

  // 担当ロック（§5.2 重複回答防止）。担当した先輩のDiscordユーザーID・表示名
  assigneeId   String?
  assigneeName String?

  // 質問者のDiscordユーザーID（§5.7 監査・紐付け用）
  requesterId String?

  // キュー一覧の見出し用の要約（§5.2 / §8）
  title String?

  // 自動ルーティング用に判定した言語・技術（将来利用、nullable）
  topic String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[] // 履歴
}

// やり取りされる個々のメッセージやコマンド実行ログ
model Message {
  id        String      @id @default(uuid())
  sessionId String
  session   Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String // テキスト内容、またはコマンド出力結果

  // コマンド実行用（Tool Calls）のフィールド
  toolCallId  String? // どのツール呼び出しに対する結果か
  commandName String? // 実行したコマンド名（例: "run_powershell", "run_bash"）

  // コマンド実行の後輩側承認状態（§5.4）。コマンド系メッセージのみ利用、通常メッセージは null
  approvalStatus ApprovalStatus?

  discordMessageId String?  @unique // Discord側のメッセージID
  createdAt        DateTime @default(now())
}

// 認証・認可用のユーザー（§5.7）。認証はDiscordに委譲し、秘匿情報は保持しない
model User {
  discordUserId String    @id // Discordの一意ユーザーID（主キー相当）
  displayName   String?
  avatarUrl     String?
  role          UserRole  @default(KISO) // ログイン時にギルドロールから判定・更新
  lastLoginAt   DateTime? // ロール再判定のタイミング管理用
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
